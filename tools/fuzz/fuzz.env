#!/usr/bin/env bash

fuzzbuild() {
  # Usage reminder
  local usage="Usage: fuzzbuild <coverage=0|1> <buildname> [np]"
  #set -Eeuo pipefail

  # Requires at least two arguments
  if (( $# < 2 )); then
    echo "Error: Not enough arguments."
    echo "$usage"
    return 1
  fi

  local coverage="$1"
  local buildname="$2"
  local mode="${3:-}"

  if [[ "$coverage" != "0" && "$coverage" != "1" ]]; then
    echo "Error: coverage must be 0 or 1"
    echo "$usage"
    return 1
  fi

  local buildtarget=""
  local compileflags=""
  local covg_conf=""
  local is_persistent="-DPERSISTENT_MODE"
  local fuzzroot="_Fuzz"
  local builddir="$fuzzroot/builds/$buildname"

  # If coverage=1, enable coverage config and activate venv
  if [[ "$coverage" == "1" ]]; then
    buildtarget="-- run-coverage"
    covg_conf="-DRMM_COVERAGE=ON"
    if [[ -f "venv/bin/activate" ]]; then
      source "venv/bin/activate"
    else
      echo "Warning: venv/bin/activate not found, coverage report or corpus generation may fail."
    fi
  fi

  if [[ "$mode" == "np" ]]; then
    is_persistent=""
  fi

  cmake \
    -DLOG_LEVEL=50 \
    -DRMM_CONFIG="host_defcfg" \
    -DHOST_VARIANT="host_fuzz" \
    -DRMM_TOOLCHAIN="afl-llvm" \
    -DCMAKE_BUILD_TYPE="Debug" \
    -DFUZZ_BUILD_NAME="$buildname" \
    -DCMAKE_C_FLAGS="$is_persistent" \
    $covg_conf $compileflags \
    -S "." -B "$builddir"

  # Build
  cmake --build "$builddir" -j"$(( "$(nproc)" / 2 ))"

  # Create bench directory and afl output link if missing
  mkdir -p "$fuzzroot/bench"
  ln -sfn /mnt/aflout "$fuzzroot/aflout"

  echo
  echo "Built with $is_persistent"
  echo "Suggested AFL commands:"
  echo "afl-fuzz -i \"$builddir/smc_corpus\" -o \"$fuzzroot/aflout/$buildname/\" -M \"m-$buildname\" -- \"./$builddir/Debug/rmm.elf\""
  echo "afl-fuzz -i \"$builddir/smc_corpus\" -o \"$fuzzroot/aflout/$buildname/\" -S \"s-$buildname\" -- \"./$builddir/Debug/rmm.elf\""

  echo
  echo "Fuzz for 1000 seconds:"
  echo "cmake --build \"$builddir\" -- run-fuzzer"

  echo
  echo "Execute with default corpus (Only for non-persistent mode):"
  echo "./$builddir/Debug/rmm.elf \"$builddir/smc_corpus/default.bin\""

  if [[ -n "$buildtarget" ]]; then
    echo
    echo "Generate coverage report:"
    echo "cmake --build \"$builddir\" $buildtarget"
  fi

  set +Eeuo pipefail
}
